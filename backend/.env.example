PORT=5000
MONGODB_URI=mongodb://localhost:27017/smartgrocery
JWT_SECRET=your_jwt_secret_key_change_in_production
NODE_ENV=development

# ===== FIREBASE CONFIGURATION (for Google Sign-In & OTP) =====
# Get these from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_CLIENT_X509_CERT_URL=your_cert_url
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_auth_domain

# ===== RAZORPAY CONFIGURATION (for Payments - India) =====
# Get these from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ===== STRIPE CONFIGURATION (for International Payments) =====
# Get these from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key

# ===== SMS/OTP PROVIDER (Optional - for Twilio) =====
# Get these from: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
